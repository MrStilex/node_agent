NODE_ID=node-001
SCHEMA_VERSION=1.0

HEARTBEAT_INTERVAL=60
SUMMARY_INTERVAL=60
FAIL_WINDOW=30
RECONNECT_WINDOW=300
RECONNECT_THRESHOLD=30
FAIL_DEDUP_WINDOW=15
CONTEXT_LOOKBACK_SEC=120
INCIDENT_DEDUP_WINDOW_SEC=30
TOPN_SIZE=10
SPOOL_DIR=/var/lib/node-agent/spool

ACCESS_LOG_PATH=/var/log/remnanode/access.log
ERROR_LOG_PATH=/var/log/remnanode/error.log
DOCKER_CONTAINER_NAME=remnanode

COLLECTOR_URL=http://collector:8080/ingest
COLLECTOR_TOKEN=
SEND_BATCH_SIZE=200
SEND_INTERVAL=5
REQUEST_TIMEOUT_SEC=5
