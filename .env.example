NODE_ID=fi-1
INGEST_URL=https://stats.example.com/ingest
INGEST_TOKEN=replace_me

SEND_BATCH_MAX=100
SEND_INTERVAL_SEC=2
HEARTBEAT_INTERVAL_SEC=60
SUMMARY_INTERVAL_SEC=60
SUMMARY_WINDOW_SEC=60

RECONNECT_WINDOW_SEC=300
RECONNECT_WARN_THRESHOLD=30
RECONNECT_CRIT_THRESHOLD=60
RECONNECT_COOLDOWN_SEC=300

FAIL_DEDUP_WINDOW_SEC=10
FAIL_MSG_MAXLEN=300
LINE_DEDUP_WINDOW_SEC=30

LOG_ACCESS_PATH=/var/log/remnanode/access.log
LOG_ERROR_PATH=/var/log/remnanode/error.log
READ_FROM_START=0

DOCKER_INCIDENTS_ENABLED=1
DOCKER_CONTAINER_NAME=remnanode

SPOOL_DIR=/var/lib/remna-agent/spool
SPOOL_MAX_EVENTS=200000
SPOOL_DROP_POLICY=drop_oldest

REQUEST_TIMEOUT_SEC=10
LOG_LEVEL=INFO
