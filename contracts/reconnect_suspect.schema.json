{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://remnawave.local/schemas/reconnect_suspect.schema.json",
  "title": "reconnect_suspect",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "event_type",
    "node_id",
    "email",
    "window",
    "window_start",
    "window_end",
    "severity",
    "reconnect_count",
    "unique_src_ip",
    "unique_src_port",
    "top_dst"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0" },
    "event_type": { "type": "string", "const": "reconnect_suspect" },
    "node_id": { "type": "string", "minLength": 1 },
    "email": { "type": "string", "minLength": 1 },
    "window": { "type": "integer", "minimum": 1 },
    "window_start": { "type": "string", "format": "date-time" },
    "window_end": { "type": "string", "format": "date-time" },
    "severity": { "type": "string", "enum": ["warn", "crit"] },
    "reconnect_count": { "type": "integer", "minimum": 1 },
    "unique_src_ip": { "type": "integer", "minimum": 0 },
    "unique_src_port": { "type": "integer", "minimum": 0 },
    "top_dst": { "type": ["string", "null"] }
  }
}
